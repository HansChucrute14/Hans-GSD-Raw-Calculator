  "weight_resolution_strategy": {
    "description": "Resolve a tensao entre a saida escalar do modelo Gompertz W(t) e os intervalos [min, max] da tabela antropometrica. Define qual ponto de peso o solver usa para calcular TER e DER.",
    "problem_statement": "O modelo Gompertz W(t) = W_max * exp(-b * exp(-c * t)) produz um valor escalar para cada idade t. A tabela antropometrica registra peso como [min, max], refletindo variabilidade biologica inter-individual. O solver precisa de UM valor de peso (BW_kg) para computar TER = 70 * BW^0.75. Sem resolucao explicita, o solver pode usar min, max, ou qualquer ponto intermediario, produzindo resultados nao-reprodutiveis.",
    "primary_weight_source": "gompertz_scalar",
    "primary_weight_source_description": "O modelo Gompertz calibrado com W_max e parametros b, c fornece a curva de crescimento CANONICA para a raca. Este e o peso esperado (E[W]) para um individuo mediano na idade t. Deve ser a fonte primaria de peso para calculos energeticos.",
    "table_role": "validation_bounds",
    "table_role_description": "A tabela antropometrica [min, max] serve como LIMITES DE VALIDACAO, nao como fonte de peso. Se W_gompertz(t) cair fora de [min, max] para a idade t, o solver deve emitir WARNING de calibracao do modelo (o Gompertz nao reflete os dados observados naquela idade).",
    "solver_rules": [
      {
        "rule_id": "WRS_001",
        "name": "use_gompertz_for_energy",
        "description": "Para calculo de TER (70 * BW^0.75) e DER (TER * k), usar EXCLUSIVAMENTE o valor escalar do Gompertz W(t) como BW_kg.",
        "implementation": "BW_kg = GRO_W_MAX_{sex} * exp(-GRO_B_PARAM * exp(-(GRO_C_{sex}_DAYS / 30.44) * t_months))",
        "rationale": "O Gompertz e um modelo parametrico suave e derivavel, essencial para o solver LP que requer funcoes de custo continuas. Intervalos [min,max] introduziriam descontinuidade e nao-reprodutibilidade."
      },
      {
        "rule_id": "WRS_002",
        "name": "table_bounds_validation",
        "description": "Para cada mes t, verificar se W_gompertz(t) esta dentro de [table_min(t), table_max(t)]. Se fora, emitir WARNING_WRS_OUT_OF_BOUNDS.",
        "severity": "WARNING",
        "rationale": "O Gompertz e calibrado nos dados da tabela. Desvios indicam: (a) mau ajuste dos parametros b/c, (b) dados interpolados com erro, ou (c) crescimento atipico em idades especificas (e.g., estirao puberal)."
      },
      {
        "rule_id": "WRS_003",
        "name": "table_mean_for_initial_guess_only",
        "description": "O ponto medio da tabela ((min+max)/2) pode ser usado APENAS como valor inicial (initial guess) para o solver NAO como peso operacional.",
        "rationale": "A media dos intervalos e um proxy grosseiro que ignora a assimetria da distribuicao de peso. O Gompertz capta a forma sigmoidal do crescimento, que a media linear nao reflete."
      },
      {
        "rule_id": "WRS_004",
        "name": "anthropometric_entry_weight_point",
        "description": "Os campos weight_male_kg e weight_female_kg na tabela antropometrica continuam como [min, max] (nao devem ser convertidos para escalares). A resolucao para escalar e responsabilidade EXCLUSIVA da estrategia WRS_001 via Gompertz.",
        "rationale": "Preservar a riqueza informacional da tabela. Converter [min,max] para escalar perderia dados de variabilidade que sao uteis para analise de sensibilidade e intervalos de confianca do solver."
      }
    ],
    "fallback_protocols": [
      {
        "condition": "Gompertz parameters not calibrated (b or c missing)",
        "action": "Use table mean (min+max)/2 as BW_kg with WARNING_WRS_FALLBACK_MEAN",
        "rationale": "Sem Gompertz calibrado, a media da tabela e o melhor proxy disponivel, embora inferior ao modelo parametrico."
      },
      {
        "condition": "Target age t not in anthropometric_table (e.g., t=4.5 months)",
        "action": "Interpolate table mean linearly between nearest months, then use Gompertz as primary validation",
        "rationale": "O Gompertz e continuo e fornece W(t) para qualquer t real. A interpolacao da tabela e apenas para informacao contextual."
      }
    ],
    "source_ref": "REF_GROWTH_GOMPERTZ",
    "note": "Esta secao resolve o Gap S4.2 (CRITICAL) identificado na analise critica. Antes desta resolucao, o solver nao tinha instrucao explicita sobre qual ponto de peso usar da tabela, criando ambiguidade que podia levar a resultados nao-reprodutiveis entre execucoes."
  },
