  "references": {
    "REF_MIN_ANT_CA_P": {
      "text": "Manter relacao Ca:P entre 1.1:1 e 1.3:1. Evita bloqueio da absorcao de fosforo ou estimulo a secrecao de PTH. Caso catastrofico Doc2: racio 12.15:1. BARF violacao tipica: 1.2:1.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "lines 199-204"
      ]
    },
    "REF_MIN_ANT_ZN_CU": {
      "text": "Relacao Zn:Cu >12:1 induz sintese de metalotioneina enterica que se liga preferencialmente ao cobre, impedindo translocacao e gerando deficiencia secundaria de cobre.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "lines 206-211"
      ]
    },
    "REF_MIN_ANT_FE_ZN": {
      "text": "Ferro livre compete com zinco pelo transportador DMT1 na membrana apical dos enterocitos.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "lines 213-216"
      ]
    },
    "REF_MIN_ANT_CA_MG": {
      "text": "Excesso de calcio diminui taxa de absorcao de magnesio por competicao nos transportadores epiteliais e paracelulares. Faixa ideal: 12:1 a 18:1.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "lines 218-221"
      ]
    },
    "REF_MIN_ANT_LYS_ARG": {
      "text": "Lisina atua como inibidor competitivo direto da arginina no transporte epitelial renal e enterico. Ingestao desproporcional compromete ciclo da ureia e sintese de oxido nitrico. Faixa ideal: 1.0:1 a 1.4:1.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "lines 223-226"
      ]
    },
    "REF_SUL_CU_PATHO": {
      "text": "Acumulacao progressiva de ions de cobre livres no citoplasma dos hepatocitos -> ultrapassa capacidade de ligacao das metalotioneinas -> reacao de Fenton -> radicais hidroxilo (OH-) -> peroxidacao lipidica da membrana mitocondrial -> apoptose celular -> hepatitis cronica associada ao cobre. AAFCO nao estabelece formalmente limite superior para cobre.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "INFERRED",
      "line_references": [
        "lines 83-84"
      ],
      "note": "Rebaixado de CONFIRMED para INFERRED (ACH-036). SUL de cobre tem regulatory_gap=true (sem limite formal AAFCO/NRC). O valor de 100mg e estimado por extrapolacao de dados de hepatotoxicidade, nao derivado de ensaio clinico formal."
    },
    "REF_SUL_FE_PATHO": {
      "text": "Excesso de ferro biodisponivel solvel (sulfatos ou quelatos) compete com zinco e manganes pelos mesmos locais de ligacao do transportador DMT1. Biodisponibilidade de carbonato/oxido: ~10%.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "line 85"
      ]
    },
    "REF_SUL_NA_PATHO": {
      "text": "Hipercalciuria por competicao Na/Ca nos canais de reabsorcao nos tubulos renais. Toxicose salina aguda: aumento abrupto da pressao osmotica plasmatica -> retracao celular cerebral -> ruptura de vasos capilares meningeos.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "line 86"
      ]
    },
    "REF_SUL_VIT_A_PATHO": {
      "text": "Niveis persistentes de retinol superiores aos limites estimulam reabsorcao osteoclastica excessiva, interferem na diferenciacao dos condrocitos, inibem sintese de colageno tipo II e agrecano, resultando em fechamento prematuro assimetrico das placas de crescimento e exostoses osseas periarticulares.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "line 87"
      ]
    },
    "REF_SUL_VIT_D3_PATHO": {
      "text": "Hiperabsorcao intestinal descontrolada de Ca e P + reabsorcao osteoclastica massiva -> hipercalcemia e hiperfosfatemia -> precipitacao e calcificacao metastatica em tecidos moles (parenquima renal, miocardio, vasos sanguineos, mucosa gastrica) -> falencia multiorganica.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "line 88"
      ]
    },
    "REF_SUL_I_PATHO": {
      "text": "Efeito Wolff-Chaikoff: excesso de iodeto intratiroideu inibe temporariamente organificacao do iodo e sintese de T4/T3 -> hipotiroidismo subclinico cronico -> TSH elevada -> bocio hiperplasico compensatorio -> atraso acentuado no crescimento osseo, alopecia, fraqueza muscular severa.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "line 89"
      ]
    },
    "REF_SUL_ZN_PATHO": {
      "text": "Excesso de zinco inibe absorcao intestinal de cobre via inducao de metalotioneina no enterocito -> deplecao sistematica de Cu -> anemia e comprometimento do sistema imunologico. Interferencia tambem com absorcao de ferro. NRC 2006 e FEDIAF 2021 nao definem limite formal, mas orientam SUL estimado em ~300mg/1000kcal.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "INFERRED",
      "line_references": [
        "lines 90-91"
      ]
    },
    "REF_SUL_MN_PATHO": {
      "text": "Excesso de manganes acumula no SNC via transporte ativo de membrana -> neurotoxicidade com sindrome parkinsoniana (tremores, rigidez, bradicinesia). Caus tambem afeta metabolismo do ferro e producao de ROS. NRC 2006 estima SUL em ~15mg/1000kcal para caes em crescimento.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "INFERRED",
      "line_references": [
        "lines 92-93"
      ]
    },
    "REF_INCL_LIVER_JUST": {
      "text": "Risco de toxicidade por Vitamina A; ate 400% de variacao no teor de retinol entre lotes de figado.",
