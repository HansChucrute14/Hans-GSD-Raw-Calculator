    },
    "REF_ALGO_GOAL_PROG": {
      "text": "Formulacao Goal Programming: Minimizar sum(w_j * (d_j_minus + d_j_plus)). Variaveis: x_i (proporcao ingrediente), a_ij (concentracao nutriente), T_j (target), d_j+/- (desvios). Restricao: d_j_minus >= 0, d_j_plus >= 0, d_j_minus * d_j_plus = 0.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "lines 244-260"
      ]
    },
    "REF_ALGO_FALLBACK": {
      "text": "Protocolos de fallback em 3 niveis: (1) Validacao por base de dados homologa filtrada, (2) Imputacao estatistica conservadora por intervalo de confianca (Mean +/- 2 sigma), (3) Exclusao parametrica ou penalizacao de seguranca (-50% beneficos, +200% toxicos).",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "lines 262-273"
      ]
    },
    "REF_SUP_CALCIDIOL": {
      "text": "Calcidiol (25-OH-D3): aumento serico de 40.5% em 1 mes. Superior a D3 para elevar/sustentar niveis sericos de 25(OH)D. Vitamina D3 (colecalciferol) em dose elevada nao produziu alteracao significativa no controle.",
