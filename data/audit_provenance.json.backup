    "REF_BIO_TYG": {
      "text": "Dietas cruas promovem menor indice de triglicerides-glicose (TyG). Melhora sensibilidade a insulina, reduz risco de perturbacoes endocrinas que afetam GH e IGF-1 durante fase critica de desenvolvimento.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "lines 127-131"
      ]
    },
    "REF_BIO_IGA": {
      "text": "Aumento significativo nos niveis fecais de IgA, IgG e fosfatase alcalina intestinal (IAP) em dietas cruas. Fortalecimento da barreira epitelial e reducao da translocacao bacteriana. Correlaciona com reducao da inflamacao sistemica que afeta a vascularizacao metafisaria.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "lines 127-131"
      ]
    },
    "REF_BIO_INSULIN": {
      "text": "Melhora na sensibilidade a insulina evidenciada por menor TyG em dietas cruas. Previne perturbacoes endocrinas que afetam GH e IGF-1 durante fase critica de desenvolvimento.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "lines 127-131"
      ]
    },
    "REF_BIO_MICROBIOME_RAW": {
      "text": "Maior diversidade alfa com taxas de Fusobacterium e Bacteroides. Reducao do pH fecal. Aumento de IgA, IgG e IAP fecais. Fortalecimento da barreira epitelial.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "lines 122-131"
      ]
    },
    "REF_BIO_MICROBIOME_EXT": {
      "text": "Amido elevado em racoes extrusadas -> fermentacao bacteriana no colon distal -> translocacao de LPS para circulacao porta -> endotoxemia metabolica -> resposta inflamatoria sistemica de baixo grau -> afeta vascularizacao metafisaria -> perturba nutricao dos condrocitos nas placas de crescimento.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "lines 122-131"
      ]
    },
    "REF_BONE_QUALITY": {
      "text": "DMO diminui significativamente com a idade (cortical + trabecular). DMO apresenta correlacao linear negativa com o peso corporal -> caes com maior porte possuem proporcionalmente menor densidade mineral por unidade de volume osseo. Metodos: DXA, qCT. Machos tem maior CMO/BMD (atribuido ao maior peso corporal).",
      "doc_ids": [
        "DOC2",
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "DOC3 line 150"
      ]
    },
    "REF_DIGEST_RAW": {
      "text": "Dietas BARF com tecidos animais frescos e sem tratamento termico apresentam ATTD da proteina bruta e da gordura significativamente superior (~90%) em comparacao com racoes secas extrusadas tradicionais (~80%). Ate 45.5% das formulacoes BARF caseiras excedem limites maximos de calcio e 27.3% nao respeitam o racio Ca:P minimo.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "lines 122-131"
      ]
    },
    "REF_CALORIC_DENSITY": {
      "text": "Densidade energetica recomendada extrusada: 3500-4000 kcal/kg MS. BARF tipico: 4500 kcal/kg MS (excede devido ao elevado teor lipidico).",
