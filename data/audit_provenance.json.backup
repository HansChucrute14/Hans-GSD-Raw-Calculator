        "DOC3"
      ],
      "quality_flag": "AUTHORITATIVE_DATABASE",
      "line_references": [
        "Monica Segal Гўв‚¬вЂќ DB de composiГѓВ§ГѓВЈo de ingredientes para cГѓВЈes"
      ],
      "applies_to": [
        "beef_green_tripe_raw"
      ],
      "nutrient_count": 12
    },
    "REF_SAFETY_BOVINE_BLOOD_PATHOGENS": {
      "text": "Sangue bovino cru: risco de patГѓВіgenos sanguГѓВ­neos (bactГѓВ©rias veiculadas hemticamente) e prГѓВ­ons (BSE teГѓВіrico, risco residual extremamente baixo em paГѓВ­ses BSE-free). MitigaГѓВ§ГѓВЈo: cozimento obrigatГѓВіrio a 71Г‚В°C interno e proveniГѓВЄncia verificada (paГѓВ­s BSE-free).",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "DOC3 Гўв‚¬вЂќ seguranГѓВ§a de ingredientes crus de origem bovina"
      ],
      "applies_to": [
        "beef_blood_raw"
      ],
      "risk_type": "microbiological"
    },
    "REF_SAFETY_BOVINE_COOKING": {
      "text": "Ingredientes bovinos com risco de patГѓВіgenos residuais se cozimento insuficiente. Cortes com tecido conectivo denso (mocotГѓВі, rabo, lГѓВ­ngua) exigem penetraГѓВ§ГѓВЈo tГѓВ©rmica adequada. MitigaГѓВ§ГѓВЈo: cozimento a 71Г‚В°C interno por mГѓВ­nimo 15 segundos. Aplica-se a beef_foot_tendon_raw, beef_tail_raw, beef_tongue_raw.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "DOC3 Гўв‚¬вЂќ protocolo de cocГѓВ§ГѓВЈo para ingredientes bovinos"
      ],
      "applies_to": [
        "beef_foot_tendon_raw",
        "beef_tail_raw",
        "beef_tongue_raw"
      ],
      "risk_type": "microbiological"
    },
    "REF_SAFETY_BOVINE_RAW_PATHOGENS": {
      "text": "Carne e vГѓВ­sceras bovinas cruas: risco de contaminaГѓВ§ГѓВЈo por Salmonella spp., Escherichia coli (incluindo STEC), Listeria monocytogenes. MitigaГѓВ§ГѓВЈo: congelamento profilГѓВЎtico a -18Г‚В°C por 72h ou cozimento a 71Г‚В°C interno. Aplica-se a todos os 7 ingredientes bovinos crus com tecido muscular/visceral exposto.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "DOC3 Гўв‚¬вЂќ seguranГѓВ§a microbiolГѓВіgica de carne bovina crua"
      ],
      "applies_to": [
        "beef_muscle_raw",
        "beef_lung_raw",
        "beef_heart_raw",
        "beef_green_tripe_raw",
        "beef_liver_raw",
        "beef_kidney_raw",
        "beef_spleen_raw"
      ],
      "risk_type": "microbiological"
    },
    "REF_SAFETY_FISH_RAW_PARASITES": {
      "text": "SalmГѓВЈo do AtlГѓВўntico cru: risco de parasitas (Diphyllobothrium latum, Anisakis simplex) e bactГѓВ©rias de decomposiГѓВ§ГѓВЈo pГѓВіs-morte. MitigaГѓВ§ГѓВЈo: congelamento a -20Г‚В°C por no mГѓВ­nimo 7 dias (ou -35Г‚В°C por 15h) antes do consumo cru, conforme FDA/EFSA.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "DOC3 Гўв‚¬вЂќ seguranГѓВ§a de pescado cru"
      ],
      "applies_to": [
        "salmon_atlantic_raw"
      ],
      "risk_type": "microbiological"
    },
    "REF_SAFETY_IRON_OVERLOAD": {
      "text": "Sangue cru (bovino e de frango): risco de sobrecarga de ferro dietГѓВ©tico. Sangue bovino contГѓВ©m ~46.5 mg Fe/100g (predominantemente heme, alta biodisponibilidade). Sangue de frango tem teor similar. MitigaГѓВ§ГѓВЈo: limitar inclusГѓВЈo a 5% da dieta; monitorar ferritina sГѓВ©rica em cГѓВЈes sensГѓВ­veis. Sobrecarga crГѓВґnica de ferro gera estresse oxidativo hepГѓВЎtico.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "DOC3 Гўв‚¬вЂќ toxicidade de minerais em dieta canina"
      ],
      "applies_to": [
        "beef_blood_raw",
        "chicken_blood_raw"
      ],
      "risk_type": "chemical_toxicity"
    },
    "REF_SAFETY_PORK_RAW_PATHOGENS": {
      "text": "Carne e vГѓВ­sceras suГѓВ­nas cruas: risco de Salmonella spp., Toxoplasma gondii, Yersinia enterocolitica. Trichinella spiralis ГѓВ© risco histГѓВіrico (controlado em suinocultura moderna mas nГѓВЈo eliminado). MitigaГѓВ§ГѓВЈo: congelamento a -18Г‚В°C por no mГѓВ­nimo 72h antes do consumo cru para reduzir carga parasitГѓВЎria. Aplica-se a pork_muscle_raw e pork_liver_raw.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "DOC3 Гўв‚¬вЂќ seguranГѓВ§a de suГѓВ­nos crus"
      ],
      "applies_to": [
        "pork_muscle_raw",
        "pork_liver_raw"
      ],
      "risk_type": "microbiological"
    },
    "REF_SAFETY_POULTRY_BLOOD_PATHOGENS": {
      "text": "Sangue de frango cru: meio altamente rico (proteГѓВ­na, ferro, umidade) e propГѓВ­cio ГѓВ  proliferaГѓВ§ГѓВЈo ultrarrГѓВЎpida de bactГѓВ©rias patogГѓВЄnicas pГѓВіs-abate. Risco de contaminaГѓВ§ГѓВЈo cruzada severa. MitigaГѓВ§ГѓВЈo: fornecer apenas fervido/desidratado ou de abate estritamente monitorado com cadeia de frio ininterrupta.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "DOC3 Гўв‚¬вЂќ seguranГѓВ§a de subprodutos avГѓВ­colas crus"
      ],
      "applies_to": [
        "chicken_blood_raw"
      ],
      "risk_type": "microbiological"
    },
    "REF_SAFETY_POULTRY_RAW_PATHOGENS": {
      "text": "Carne e vГѓВ­sceras de frango crus: risco de contaminaГѓВ§ГѓВЈo por Salmonella spp. e Campylobacter spp. (prevalГѓВЄncia elevada em aves comerciais). PГѓВ©s de frango adicionalmente expostos a contaminaГѓВ§ГѓВЈo de cama aviГѓВЎria. MitigaГѓВ§ГѓВЈo: congelamento a -18Г‚В°C, manuseio higiГѓВЄnico rigoroso, lavagem sanitГѓВЎria. Para pГѓВ©s de frango: cozimento a 71Г‚В°C ou exclusГѓВЈo de dietas cruas sem rigoroso protocolo de limpeza. Aplica-se a 5 ingredientes de frango.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "DOC3 Гўв‚¬вЂќ seguranГѓВ§a microbiolГѓВіgica de aves cruas"
      ],
      "applies_to": [
        "chicken_muscle_raw",
        "chicken_heart_raw",
        "chicken_kidney_raw",
        "chicken_liver_raw",
        "chicken_foot_tendon_raw"
      ],
      "risk_type": "microbiological"
    },
    "REF_SAFETY_VITAMIN_A_TOXICITY": {
      "text": "FГѓВ­gado cru (bovino, de frango, suГѓВ­no): risco de hipervitaminose A por elevado teor de retinol prГѓВ©-formado. FГѓВ­gado bovino: ~16898 IU/100g com variabilidade de Г‚В±400% entre lotes. MitigaГѓВ§ГѓВЈo: limitar inclusГѓВЈo a 5% da dieta. NГѓВЈo suplementar vitamina A adicional quando fГѓВ­gado estГѓВЎ presente na formulaГѓВ§ГѓВЈo. Risco sistГѓВЄmico: hepatotoxicidade, teratogenicidade, fechamento prematuro de placas de crescimento.",
      "doc_ids": [
        "DOC3"
      ],
      "quality_flag": "CONFIRMED",
      "line_references": [
        "DOC3 Гўв‚¬вЂќ toxicidade por vitamina A em vГѓВ­sceras"
      ],
      "applies_to": [
        "beef_liver_raw",
        "chicken_liver_raw",
        "pork_liver_raw"
      ],
      "risk_type": "chemical_toxicity"
    },
