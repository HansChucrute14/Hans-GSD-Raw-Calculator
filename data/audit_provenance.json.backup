  "algorithm_logic": {
    "goal_programming": {
      "mathematical_formulation": {
        "variables": {
          "x_i": "Proporcao de inclusao do ingrediente i no alimento (sum=1)",
          "a_ij": "Concentracao de nutriente j por unidade do ingrediente i",
          "T_j": "Valor-alvo para nutriente/meta j",
          "d_j_minus": "Variavel de desvio negativo",
          "d_j_plus": "Variavel de desvio positivo",
          "constraint": "d_j_minus >= 0, d_j_plus >= 0, d_j_minus * d_j_plus = 0"
        },
        "general_constraint": "sum(x_i * a_ij) + d_j_minus - d_j_plus = T_j",
        "objective_function": "Minimize sum(w_j * (d_j_minus + d_j_plus))"
      },
      "source_ref": "REF_ALGO_GOAL_PROG"
    },
    "fallback_protocols": [
      {
        "level": 1,
        "name": "Validacao por Base de Dados Homologa Filtrada",
